# Identificación de la aplicación para APIs públicas (OSM exige User-Agent real)
APP_NAME=SistemasFV-Chile
APP_VERSION=0.1.0
CONTACT_EMAIL=dromeroponce29@gmail.com

# Endpoints externos (no requieren API key)
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_3
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup

# Timeouts HTTP en segundos
HTTP_TIMEOUT=30

# Configuración regional
DEFAULT_COUNTRY=Chile
DEFAULT_TIMEZONE=America/Santiago

# Hemisferio (para corregir azimut en PVGIS: SOUTH=180 norte, NORTH=0 sur)
HEMISPHERE=SOUTH

# Persistencia
DATABASE_URL=sqlite+aiosqlite:///./sistemas_fv.db
